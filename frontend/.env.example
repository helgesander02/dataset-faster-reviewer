# ===================================
# Frontend 本地開發環境變數
# ===================================
# 注意: 此文件僅用於本地開發 (不使用 Docker)
# Docker 部署時所有配置由根目錄 .env 統一管理

# API Configuration
NEXT_PUBLIC_API_BASE_URL=http://localhost:8123

# Environment
NODE_ENV=development

# Performance
NEXT_PUBLIC_IMAGES_PER_PAGE=9
NEXT_PUBLIC_DATASET_PER_PAGE=100
NEXT_PUBLIC_JOB_REFRESH_INTERVAL=60000

# Feature Flags
NEXT_PUBLIC_ENABLE_RETRY=true
NEXT_PUBLIC_MAX_RETRIES=2

# Optional
NEXT_TELEMETRY_DISABLED=1
