# 主要資料根目錄 (包含 datasets 和 images)
# Windows 範例: C:\Users\YourName\Desktop\example_root
# macOS 範例: /Users/yourname/Desktop/example_root
# Linux 範例: /home/yourname/example_root
DATA_ROOT_PATH=/Users/sanderhsu/Desktop/example_root

# 備份目錄
# Windows 範例: C:\Users\YourName\Desktop\backups
# macOS 範例: /Users/yourname/Desktop/backups
# Linux 範例: /home/yourname/backups
BACKUP_PATH=/Users/sanderhsu/Desktop/backups

NEXT_PUBLIC_API_BASE_URL=
ALLOWED_ORIGINS=http://localhost:3000

TRAEFIK_PORT=3000
TRAEFIK_LOG_LEVEL=INFO

NEXT_PUBLIC_IMAGES_PER_PAGE=9
NEXT_PUBLIC_DATASET_PER_PAGE=100
NEXT_PUBLIC_JOB_REFRESH_INTERVAL=60000
NEXT_PUBLIC_ENABLE_RETRY=true
NEXT_PUBLIC_MAX_RETRIES=2

NODE_ENV=production
GIN_MODE=release

# ============================================
# 使用說明
# ============================================
#
# 1. 複製此文件:
#    cp .env.example .env
#
# 2. 編輯 .env 文件，修改以下必要設定:
#    - DATA_ROOT_PATH: 你的資料目錄絕對路徑
#    - BACKUP_PATH: 你的備份目錄絕對路徑
#    - ALLOWED_ORIGINS: 如需遠程訪問，添加訪問 URL
#
# 3. 啟動服務:
#    docker-compose up -d
#
# 4. 訪問應用:
#    - 應用主頁: http://localhost:3000
#    - API 端點: http://localhost:3000/api/*
#    - Traefik Dashboard: http://localhost:8080
#
# 5. 遠程訪問 (Port Forward):
#    如果需要通過 port forward 訪問 (如 http://10.2.142.123:3456):
#    - 設定 port forward: 遠程端口 → localhost:3000
#    - 修改 ALLOWED_ORIGINS: http://localhost:3000,http://10.2.142.123:3456
#    - 重啟服務: docker-compose restart
#
# 6. 跨平台路徑注意事項:
#    - Windows: 使用反斜線 \ 或正斜線 / 都可以
#              例如: C:\Users\Name\path 或 C:/Users/Name/path
#    - macOS/Linux: 使用正斜線 /
#                   例如: /Users/name/path
#    - macOS/Linux 可使用 ~ 代表家目錄
#              例如: ~/Desktop/example_root
#
# 7. 如果不創建 .env 文件:
#    - DATA_ROOT_PATH 預設: ./data/example_root
#    - BACKUP_PATH 預設: ./data/backups
#    - TRAEFIK_PORT 預設: 3000
